{
  "name": "@nattstack/ui",
  "version": "0.0.30",
  "description": "A collection of reusable React components built with Base UI, TypeScript, and CSS Modules",
  "keywords": [
    "base-ui",
    "components",
    "css",
    "react",
    "tailwindcss",
    "ui"
  ],
  "homepage": "https://github.com/nattstack/ui#readme",
  "bugs": {
    "url": "https://github.com/nattstack/ui/issues"
  },
  "author": "Natt <hello@natt.sh> (https://natt.sh)",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/nattstack/ui.git"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "main": "./dist/components/index.js",
  "module": "./dist/components/index.js",
  "types": "./dist/components/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/components/index.d.ts",
      "import": "./dist/components/index.js"
    },
    "./baseline": "./dist/baseline/index.css",
    "./colors": "./dist/colors/index.css",
    "./tailwind-colors": "./dist/tailwind-colors/index.css",
    "./tailwind-tokenless-10": "./dist/tailwind-tokenless/10/index.css",
    "./tailwind-tokenless-16": "./dist/tailwind-tokenless/16/index.css"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsdown",
    "check:type": "tsc",
    "dev": "tsdown --watch",
    "prepublishOnly": "bun run build",
    "release": "bun publish"
  },
  "dependencies": {
    "@base-ui/react": "1.4.0"
  },
  "devDependencies": {
    "@tsdown/css": "0.21.8",
    "@types/bun": "1.3.12",
    "tsdown": "0.21.8",
    "typescript": "5.9.3"
  },
  "peerDependencies": {
    "@types/react": "^18 || ^19",
    "react": "^18 || ^19",
    "react-dom": "^18 || ^19"
  }
}
